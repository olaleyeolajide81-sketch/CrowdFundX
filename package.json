{
  "name": "crowdfundx",
  "version": "1.0.0",
  "description": "Decentralized crowdfunding platform built on Stellar",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install && cd ../smart-contracts && cargo build",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "test": "npm run test:backend && npm run test:frontend && npm run test:contracts",
    "test:backend": "cd backend && npm run test:coverage",
    "test:frontend": "cd frontend && npm run test:coverage",
    "test:contracts": "cd smart-contracts && cargo test",
    "test:e2e": "cd tests/e2e_tests && npm test",
    "deploy:contracts": "cd scripts && node deploy_contracts.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "lint": "npm run lint:backend && npm run lint:frontend && npm run lint:contracts",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:contracts": "cd smart-contracts && cargo clippy -- -D warnings",
    "format": "npm run format:backend && npm run format:frontend && npm run format:contracts",
    "format:backend": "cd backend && npm run format",
    "format:frontend": "cd frontend && npm run format",
    "format:contracts": "cd smart-contracts && cargo fmt",
    "clean": "npm run clean:backend && npm run clean:frontend && npm run clean:contracts",
    "clean:backend": "cd backend && rm -rf coverage",
    "clean:frontend": "cd frontend && rm -rf coverage dist",
    "clean:contracts": "cd smart-contracts && cargo clean"
  },
  "keywords": [
    "stellar",
    "blockchain",
    "crowdfunding",
    "web3",
    "soroban",
    "decentralized",
    "fundraising"
  ],
  "author": "CrowdFundX Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/CrowdFundX.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/CrowdFundX/issues"
  },
  "homepage": "https://crowdfundx.io"
}
