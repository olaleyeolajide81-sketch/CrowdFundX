# Stellar Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Contract Addresses (filled after deployment)
CAMPAIGN_MANAGER_CONTRACT=
FUNDING_POOL_CONTRACT=
REWARD_SYSTEM_CONTRACT=
GOVERNANCE_CONTRACT=

# Backend Configuration
PORT=3001
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
CORS_ORIGIN=http://localhost:3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/crowdfundx_test
REDIS_URL=redis://localhost:6379

# IPFS Configuration
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# KYC/AML Service Configuration
KYC_SERVICE_API_KEY=your-kyc-service-api-key
KYC_SERVICE_URL=https://api.kyc-service.com

# Analytics Configuration
ANALYTICS_API_KEY=your-analytics-api-key
ANALYTICS_URL=https://api.analytics-service.com

# Security Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=your-session-secret-change-this

# Frontend Configuration
REACT_APP_STELLAR_NETWORK=testnet
REACT_APP_HORIZON_URL=https://horizon-testnet.stellar.org
REACT_APP_API_URL=http://localhost:3001
REACT_APP_IPFS_GATEWAY=https://ipfs.io/ipfs/

# Development Configuration
LOG_LEVEL=debug
ENABLE_MOCK_DATA=true
SKIP_KYC_IN_DEV=true

# Production Configuration (uncomment for production)
# NODE_ENV=production
# STELLAR_NETWORK=mainnet
# STELLAR_HORIZON_URL=https://horizon.stellar.org
# STELLAR_SOROBAN_RPC_URL=https://soroban.stellar.org
# MONGODB_URI=mongodb://your-production-db/crowdfundx
# REDIS_URL=redis://your-production-redis:6379
# LOG_LEVEL=info
# ENABLE_MOCK_DATA=false
# SKIP_KYC_IN_DEV=false
